{
  "name": "muse",
  "version": "0.9.3",
  "description": "Agent skill that generates beautiful HTML pages for diagrams, diff reviews, plan reviews, slide decks, and data tables",
  "license": "MIT",
  "homepage": "https://github.com/edheltzel/Muse#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edheltzel/Muse.git"
  },
  "bugs": {
    "url": "https://github.com/edheltzel/Muse/issues"
  },
  "keywords": [
    "agent-skill",
    "pi-package",
    "claude-code-plugin",
    "claude-marketplace",
    "omp",
    "oh-my-pi",
    "codex",
    "openclaw",
    "cursor",
    "diagrams",
    "html",
    "visualization",
    "diff-review",
    "plan-review",
    "slides",
    "mermaid",
    "interactive-plans",
    "mdx"
  ],
  "files": [
    "plugins/Muse",
    ".claude-plugin",
    ".agents/plugins/marketplace.json",
    "configs",
    "install-pi.sh",
    "README.md",
    "AGENTS.md",
    "docs/assets",
    "docs/dox.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "puppeteer"
  ],
  "config": {
    "testedAgentBrowserVersion": "0.31.1"
  },
  "scripts": {
    "test": "bun test",
    "build": "vp build --config vite.config.ts",
    "check": "vp run test && vp run component-explorer:test-browser && vp run visual-plan:build",
    "visual-plan:render": "bun plugins/Muse/skills/muse/tools/interactive-plan/render.ts",
    "visual-plan:serve": "bun plugins/Muse/skills/muse/tools/interactive-plan/server.ts",
    "component-explorer:render": "bun plugins/Muse/skills/muse/tools/interactive-plan/render.ts tests/fixtures/interactive-plans/component-library-showcase",
    "component-explorer:serve": "bun plugins/Muse/skills/muse/tools/interactive-plan/server.ts tests/fixtures/interactive-plans/component-library-showcase 7375",
    "component-explorer:test-browser": "bun tests/component-explorer.browser.ts",
    "visual-plan:runtime:build": "bun build plugins/Muse/skills/muse/tools/interactive-plan/runtime-entry.ts --target bun --format esm --minify --outfile plugins/Muse/skills/muse/tools/interactive-plan/runtime.mjs",
    "visual-plan:build": "vp build --config vite.config.ts && vp run visual-plan:runtime:build"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "happy-dom": "^20.10.6",
    "puppeteer": "25.3.0",
    "vite-plus": "0.2.2"
  },
  "pi": {
    "skills": [
      "./plugins/Muse"
    ],
    "prompts": [
      "./plugins/Muse/commands"
    ]
  },
  "dependencies": {
    "parse5": "8.0.1"
  }
}
