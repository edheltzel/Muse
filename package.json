{
  "name": "visual-explainer",
  "version": "0.8.0",
  "description": "Agent skill that generates beautiful HTML pages for diagrams, diff reviews, plan reviews, slide decks, and data tables",
  "license": "MIT",
  "homepage": "https://github.com/edheltzel/visual-explainer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edheltzel/visual-explainer.git"
  },
  "bugs": {
    "url": "https://github.com/edheltzel/visual-explainer/issues"
  },
  "keywords": [
    "agent-skill",
    "pi-package",
    "claude-code-plugin",
    "claude-marketplace",
    "codex",
    "opencode",
    "openclaw",
    "cursor",
    "diagrams",
    "html",
    "visualization",
    "diff-review",
    "plan-review",
    "slides",
    "mermaid",
    "interactive-plans",
    "mdx"
  ],
  "files": [
    "plugins/VisualExplainer",
    ".claude-plugin",
    "configs",
    "install-pi.sh",
    "README.md",
    "AGENTS.md",
    "docs/assets",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "test": "bun test",
    "build": "vp build --config vite.config.ts",
    "check": "vp run test && vp run visual-plan:build",
    "visual-plan:render": "bun plugins/VisualExplainer/skills/visual-explainer/tools/interactive-plan/render.ts",
    "visual-plan:serve": "bun plugins/VisualExplainer/skills/visual-explainer/tools/interactive-plan/server.ts",
    "visual-plan:build": "vp build --config vite.config.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "vite-plus": "0.2.2"
  },
  "pi": {
    "skills": [
      "./plugins/VisualExplainer"
    ],
    "prompts": [
      "./plugins/VisualExplainer/commands"
    ]
  }
}
